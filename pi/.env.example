# Copy this file to `pi/.env` and fill in real values. `.env` is gitignored.
#
# === Cloudflare R2 ===
# 1. https://dash.cloudflare.com  →  R2 Object Storage  (enable if needed)
# 2. Create a bucket, e.g. "vigil-recordings"
# 3. Your ACCOUNT_ID is visible on the R2 overview page
# 4. R2 sidebar → "Manage R2 API Tokens" → Create API Token
#      - Permissions: Object Read & Write
#      - Specify bucket: vigil-recordings
#      - Save the Access Key ID and Secret (shown once)

VIGIL_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
VIGIL_S3_ACCESS_KEY_ID=<your-r2-access-key-id>
VIGIL_S3_SECRET_ACCESS_KEY=<your-r2-secret-access-key>

# === Dashboard (vigil-agent) ===
# Shared secret matching VIGIL_DEVICE_API_KEY on the dashboard side.
VIGIL_DASHBOARD_URL=https://vigil-two-olive.vercel.app
VIGIL_DEVICE_API_KEY=<paste-the-key-from-vercel-env>
